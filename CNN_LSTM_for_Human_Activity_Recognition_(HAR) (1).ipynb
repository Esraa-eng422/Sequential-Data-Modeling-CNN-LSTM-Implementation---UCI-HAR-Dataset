      "source": [
        "# =============================================================================\n",
        "# Cell 3: Data Preprocessing for CNN-LSTM Architecture\n",
        "# =============================================================================\n",
        "\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "# 1. Separate features (X) and labels (y)\n",
        "# The last column is typically the 'Activity' label\n",
        "X_train = train_df.iloc[:, :-1]\n",
        "y_train = train_df.iloc[:, -1]\n",
        "X_test = test_df.iloc[:, :-1]\n",
        "y_test = test_df.iloc[:, -1]\n",
        "\n",
        "print(\"=== Label Type Check ===\")\n",
        "print(f\"y_train type: {type(y_train.values[0])}\")\n",
        "print(f\"y_train sample values: {y_train.values[:5]}\")\n",
        "\n",
        "# 2. Drop 'subject' column if exists (not needed for classification)\n",
        "if 'subject' in X_train.columns:\n",
        "    X_train = X_train.drop(columns=['subject'])\n",
        "    X_test = X_test.drop(columns=['subject'])\n",
        "\n",
        "# 3. Convert string labels to numeric (0-5) using LabelEncoder\n",
        "# This fixes the TypeError when labels are strings like 'Walking', 'Sitting'\n",
        "label_encoder = LabelEncoder()\n",
        "y_train_encoded = label_encoder.fit_transform(y_train)\n",
        "y_test_encoded = label_encoder.transform(y_test)\n",
        "\n",
        "print(f\"\\n=== Encoded Labels ===\")\n",
        "print(f\"Classes: {label_encoder.classes_}\")\n",
        "print(f\"Encoded y_train sample: {y_train_encoded[:5]}\")\n",
        "\n",
        "# Activity names for display (from label encoder)\n",
        "activity_names = label_encoder.classes_\n",
        "\n",
        "print(f\"\\n=== Number of Classes: {len(activity_names)} ===\")\n",
        "print(f\"Activities: {activity_names}\")\n",
        "\n",
        "# 4. Normalize the data (Important for CNN and LSTM convergence)\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "# 5. Reshape data for CNN-LSTM input shape (Samples, Time Steps, Features)\n",
        "# This dataset has 561 features per sample\n",
        "# We will treat the 561 features as time steps for Conv1D\n",
        "n_features = X_train_scaled.shape[1]  # 561\n",
        "\n",
        "# Reshape to (Samples, Time Steps, Channels)\n",
        "# Here Time Steps = 561 and Channels = 1\n",
        "X_train_reshaped = X_train_scaled.reshape(-1, n_features, 1)\n",
        "X_test_reshaped = X_test_scaled.reshape(-1, n_features, 1)\n",
        "\n",
        "print(f\"\\n=== Data Shape After Reshape ===\")\n",
        "print(f\"X_train shape: {X_train_reshaped.shape}\")  # Should be (samples, 561, 1)\n",
        "print(f\"X_test shape: {X_test_reshaped.shape}\")\n",
        "\n",
        "# 6. Convert labels to One-Hot Encoding for multi-class classification\n",
        "y_train_cat = to_categorical(y_train_encoded, num_classes=len(activity_names))\n",
        "y_test_cat = to_categorical(y_test_encoded, num_classes=len(activity_names))\n",
        "\n",
        "print(f\"\\n=== One-Hot Encoded Shape ===\")\n",
        "print(f\"y_train_cat shape: {y_train_cat.shape}\")\n",
        "print(f\"y_test_cat shape: {y_test_cat.shape}\")"
      ],
