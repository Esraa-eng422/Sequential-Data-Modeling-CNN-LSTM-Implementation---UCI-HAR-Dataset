      "cell_type": "code",
      "source": [
        "# =============================================================================\n",
        "# Cell 4: Build CNN-LSTM Model ,
        "# =============================================================================\n",
        "\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Conv1D, MaxPooling1D, LSTM, Dense, Dropout, Input, Reshape\n",
        "\n",
        "def create_cnn_lstm_model(input_shape, num_classes):\n",
        "    \"\"\"\n",
        "    Build CNN-LSTM model according to Lecture 4 Hybrid Architecture\n",
        "    Architecture: CNN -> Reshape -> LSTM -> Dense\n",
        "    Note: We avoid Flatten to preserve temporal dimension for LSTM\n",
        "    \"\"\"\n",
        "    model = Sequential()\n",
        "\n",
        "    # Add Input layer first (recommended by Keras)\n",
        "    model.add(Input(shape=input_shape))\n",
        "\n",
        "    # 1️⃣ CNN Layer (Spatial Feature Extraction)\n",
        "    # According to Lecture 4 Slide 11: CNN extracts Spatial Features\n",
        "    # We use Conv1D because data is sensor signals (1D sequence)\n",
        "    model.add(Conv1D(filters=128, kernel_size=3, activation='relu', padding='same'))\n",
        "    model.add(MaxPooling1D(pool_size=2))\n",
        "    model.add(Dropout(0.3))  # Prevent Overfitting\n",
        "\n",
        "    model.add(Conv1D(filters=64, kernel_size=3, activation='relu', padding='same'))\n",
        "    model.add(MaxPooling1D(pool_size=2))\n",
        "    model.add(Dropout(0.3))\n",
        "\n",
        "    # 2️⃣ Reshape Layer (Instead of Flatten)\n",
        "    # Convert CNN output to 3D shape for LSTM input (time_steps, features)\n",
        "    # After CNN: (batch, time_steps/4, 64) - we keep it 3D for LSTM\n",
        "    # No reshape needed here since Conv1D already outputs 3D\n",
        "\n",
        "    # 3️⃣ LSTM Layer (Temporal Dependencies)\n",
        "    # According to Lecture 4 Slide 4-5: LSTM learns Temporal Dependencies\n",
        "    # Overcomes Vanishing Gradient Problem using Gates (Forget, Input, Output)\n",
        "    # Input is already 3D from Conv1D: (batch, time_steps, features)\n",
        "    model.add(LSTM(units=128, return_sequences=False))\n",
        "    model.add(Dropout(0.3))\n",
        "\n",
        "    # 4️⃣ Dense Layer (Final Output)\n",
        "    model.add(Dense(64, activation='relu'))\n",
        "    model.add(Dense(num_classes, activation='softmax'))\n",
        "\n",
        "    return model\n",
        "\n",
        "# Create the model\n",
        "input_shape = (X_train_reshaped.shape[1], X_train_reshaped.shape[2])\n",
        "model = create_cnn_lstm_model(input_shape, len(activity_names))\n",
        "\n",
        "# Display model summary to see layers and dimensions\n",
        "print(\"\\n=== CNN-LSTM Model Summary ===\")\n",
        "model.summary()"
      ],
