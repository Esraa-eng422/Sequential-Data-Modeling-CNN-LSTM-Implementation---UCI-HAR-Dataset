        "# =============================================================================\n",
        "# Cell 2: Load Data from Kaggle Input Path\n",
        "# =============================================================================\n",
        "\n",
        "# Correct path based on your Kaggle dataset structure\n",
        "data_path = '/kaggle/input/datasets/organizations/uciml/human-activity-recognition-with-smartphones/'\n",
        "\n",
        "# Display available files to confirm the path\n",
        "print(\"Available files in the dataset:\")\n",
